RewriteEngine On

# Existing files and directories should load normally.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Friendly public profile routes like /zehra should render profile.html.
RewriteRule ^([A-Za-z0-9._-]+)$ /profile.html?u=$1 [L,QSA]
